# Copy to .env and adjust for Docker Compose (merged with docker-compose.yml)
#
#   cp .env.example .env
#   # then add or override these for compose:

# Build target: lite | full | ollama (ollama image bundles Ollama inside app — prefer profile `ollama` instead)
KOTAEMON_BUILD_TARGET=full

# Host port mapping
GRADIO_HOST_PORT=7860
OLLAMA_HOST_PORT=11434
TEI_HOST_PORT=8080

# App data on host (bind mount). Change to an absolute path if needed.
KOTAEMON_DATA_DIR=./ktem_app_data

# Inside compose network (default when using: docker compose --profile ollama up)
KH_OLLAMA_URL=http://ollama:11434/v1/

# Ollama model names (pull after start: docker compose exec ollama ollama pull qwen2.5:7b)
LOCAL_MODEL=qwen2.5:7b
LOCAL_MODEL_EMBEDDINGS=nomic-embed-text

# Optional tuning for structured ingestion
INGESTION_V2_MAX_CHUNK_CHARS=4200

# Evaluation is uncapped by default. Optional low-memory profile:
# RAGAS_EVAL_MAX_WORKERS=1
# RAGAS_EVAL_BATCH_SIZE=1
# RAGAS_EVAL_METRICS_PER_BATCH=1
# RAGAS_EVAL_OLLAMA_RECYCLE_METRIC_BATCHES=true
# RAG_EVAL_MAX_CONTEXT_TOKENS=2200
# RAG_EVAL_MAX_OUTPUT_TOKENS=256
# RAG_EVAL_OLLAMA_RECYCLE_QUESTIONS=2
# RAG_EVAL_GC_EVERY=1

# If Kotaemon runs in Docker but Ollama runs on the host machine instead of profile `ollama`:
# KH_OLLAMA_URL=http://host.docker.internal:11434/v1/

# TEI reranker (with --profile reranker); register in UI Resources as TeiFastReranking:
# endpoint_url: http://reranker:80   (service name on compose network)
# or from host browser: http://localhost:8080
